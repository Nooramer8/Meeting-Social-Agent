# Groq (free tier): transcription + summarization. Keys: https://console.groq.com/keys
GROQ_API_KEY=gsk-your-groq-key-here
TRANSCRIPTION_BACKEND=groq
TRANSCRIPTION_MODEL=whisper-large-v3-turbo
SUMMARY_BACKEND=groq
SUMMARY_MODEL=openai/gpt-oss-20b
CLOUD_REQUEST_TIMEOUT_SECONDS=180
CLOUD_TRANSCRIPTION_RETRIES=2
CLOUD_TRANSCRIPTION_RETRY_DELAY_SECONDS=2

# OpenAI: optional (needs billing / quota). Used when backends below are set to openai.
OPENAI_API_KEY=sk-your-key-here

# TRANSCRIPTION_BACKEND=openai
# TRANSCRIPTION_MODEL=gpt-4o-transcribe

# SUMMARY_BACKEND=openai
# SUMMARY_MODEL=gpt-4o-mini

# Meeting language: auto, ar, en, or another ISO-639-1 code supported by transcription.
# Choose ar in the UI for Arabic meetings.
DEFAULT_LANGUAGE=auto

# Meta / Facebook Pages publishing
META_GRAPH_VERSION=v25.0
FACEBOOK_PAGE_ID=your-page-id
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token

# Instagram professional account publishing
INSTAGRAM_USER_ID=your-instagram-business-or-creator-id
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# Needed for Instagram image publishing.
# Must be a public HTTPS URL where /storage/generated/... images are reachable after deployment.
PUBLIC_BASE_URL=https://your-domain.com

# Trained/local models in production.
# Keep models out of Git. Upload each final model folder as a Hugging Face repo,
# or upload a .zip/.tar.gz archive to S3/R2 and set the matching URL.
TRAINED_TRANSCRIPTION_BACKEND=disabled
TRAINED_ASR_MODEL_PATH=models/asr/whisper-ar-meetings
# TRAINED_ASR_HF_REPO_ID=your-user/whisper-ar-meetings
# TRAINED_ASR_ARCHIVE_URL=https://your-bucket.example.com/whisper-ar-meetings.zip

TRAINED_SUMMARY_BACKEND=disabled
TRAINED_SUMMARY_MODEL_PATH=models/summarizer/meeting-summary-ar
# TRAINED_SUMMARY_HF_REPO_ID=your-user/meeting-summary-ar
# TRAINED_SUMMARY_ARCHIVE_URL=https://your-bucket.example.com/meeting-summary-ar.zip
# HUGGINGFACE_TOKEN=hf_your_token_if_private

# Local app settings
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_PATH=./storage/app.db
